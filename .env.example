# Parlez environment — copy to `.env` and fill in to use the real providers.
# Without these, the app runs on the built-in mock service (no keys needed).

# --- Mobile app (EXPO_PUBLIC_* are inlined into the bundle) ---
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# 'mock' (default) or 'supabase' to use the real Whisper/Claude/ElevenLabs BFF
EXPO_PUBLIC_PARLEZ_SERVICE=mock

# --- RevenueCat (paywall). Public SDK keys — safe to inline in the bundle. ---
# RevenueCat dashboard > Project > API keys > "App-specific" public keys.
# NOTE: .env is gitignored and NOT uploaded to EAS cloud builds — for those,
# these must ALSO live in eas.json env. Without them the paywall shows no tiers
# and Restore always fails ("No purchases found").
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
EXPO_PUBLIC_REVENUECAT_IOS_KEY=

# --- Edge Function secrets ---
# Set these on Supabase, NOT in this file:
#   supabase secrets set OPENAI_API_KEY=... ANTHROPIC_API_KEY=... ELEVENLABS_API_KEY=...
#
# OPENAI_API_KEY            — Whisper speech-to-text
# ANTHROPIC_API_KEY         — Claude conversation engine
# ANTHROPIC_MODEL           — optional, defaults to claude-sonnet-4-5
# ELEVENLABS_API_KEY        — Camille's text-to-speech
# ELEVENLABS_VOICE_CAMILLE  — ElevenLabs voice id for the default gender-neutral voice
# ELEVENLABS_VOICE_CLAIRE   — ElevenLabs voice id for the alternative female voice
# ELEVENLABS_VOICE_HENRI    — ElevenLabs voice id for the male voice
# ELEVENLABS_VOICE_DEFAULT  — fallback voice id
# PARLEZ_MOCK               — set 'true' to stub the turn function without keys
# REVENUECAT_SECRET_KEY     — RC secret API key; used by delete-account to wipe the subscriber
# RC_WEBHOOK_SECRET         — shared secret for the revenuecat-webhook auth header.
#                             Set the SAME value in RevenueCat > Integrations > Webhooks
#                             as `Authorization: Bearer <value>`.
