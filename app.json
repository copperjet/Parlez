{
  "expo": {
    "name": "Parlez",
    "slug": "Parlez",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "parlez",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.denny32.parlez",
      "icon": "./assets/images/icon.png",
      "supportsTablet": false,
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ],
        "NSSpeechRecognitionUsageDescription": "Parlez uses speech recognition so Camille can understand your French when you are offline.",
        "NSMicrophoneUsageDescription": "Parlez listens to your voice so Camille can speak with you."
      },
      "entitlements": {
        "com.apple.developer.applesignin": [
          "Default"
        ]
      }
    },
    "android": {
      "package": "com.denny32.parlez",
      "versionCode": 9,
      "adaptiveIcon": {
        "backgroundColor": "#FBF9F6",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "RECORD_AUDIO",
        "INTERNET",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-logo.png",
          "imageWidth": 140,
          "backgroundColor": "#FBF9F6",
          "dark": {
            "backgroundColor": "#15130F"
          },
          "android": {
            "image": "./assets/images/splash-logo.png",
            "imageWidth": 140
          }
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Parlez listens to your voice so Camille can speak with you."
        }
      ],
      "expo-sqlite",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Parlez listens to your voice so Camille can speak with you.",
          "speechRecognitionPermission": "Parlez uses speech recognition so Camille can understand your French when you are offline."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.4"
          },
          "android": {
            "minSdkVersion": 28
          }
        }
      ],
      "expo-asset",
      "expo-image",
      "expo-apple-authentication",
      "./scripts/withPrivacyManifest"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "edca72fd-af2f-49ed-a0f5-fbdde06e73ac"
      }
    },
    "owner": "acecode10"
  }
}
